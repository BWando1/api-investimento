{
  "openapi": "3.0.3",
  "info": {
    "title": "API Investimento",
    "version": "1.0.0",
    "description": "Documentação pública da API de investimento"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/perfil-risco/{clienteId}": {
      "get": {
        "summary": "Consulta o perfil de risco de um cliente",
        "parameters": [
          {
            "name": "clienteId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil calculado"
          },
          "404": {
            "description": "Cliente não encontrado"
          }
        }
      }
    },
    "/simular-investimento": {
      "post": {
        "summary": "Realiza uma simulação de investimento",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Simulação concluída"
          },
          "400": {
            "description": "Dados inválidos"
          }
        }
      }
    },
    "/telemetria": {
      "get": {
        "summary": "Lista métricas agregadas de telemetria",
        "responses": {
          "200": {
            "description": "Telemetria retornada"
          }
        }
      }
    },
    "/produtos-recomendados/{perfil}": {
      "get": {
        "summary": "Lista produtos recomendados por perfil",
        "parameters": [
          {
            "name": "perfil",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de produtos"
          }
        }
      }
    },
    "/simulacoes": {
      "get": {
        "summary": "Lista simulações",
        "responses": {
          "200": {
            "description": "Lista de simulações"
          }
        }
      }
    }
  }
}
